PROJECT_NAME           = "RUS_Lab1_Bosnjak"
PROJECT_BRIEF          = "Lab1: Upravljanje višestrukim prekidima na ESP32"
OUTPUT_DIRECTORY       = ./docs
CREATE_SUBDIRS         = YES
DOXYFILE_ENCODING      = UTF-8

USE_MDFILE_AS_MAINPAGE = README.md

INPUT                  = .
RECURSIVE              = YES
FILE_PATTERNS          = *.ino *.c *.h *.md
EXTENSION_MAPPING      = ino=c

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_RTF           = NO

HTML_COLORSTYLE        = AUTO_LIGHT
HTML_DYNAMIC_SECTIONS  = YES
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
SHOW_USED_FILES        = YES
SHOW_FILES             = YES

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
OPTIMIZE_OUTPUT_FOR_C  = YES

HAVE_DOT               = YES
DOT_PATH               = /usr/bin/dot
DOT_NUM_THREADS        = 2
DOT_FONTNAME           = Helvetica
DOT_FONTSIZE           = 10

CLASS_DIAGRAMS         = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
INCLUDE_GRAPH          = YES
INTERACTIVE_SVG        = YES

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_INCOMPLETE_DOC = YES

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
SKIP_FUNCTION_MACROS   = NO

OUTPUT_LANGUAGE        = English
EXCLUDE_SYMLINKS       = YES
TAB_SIZE               = 4
QUIET                  = NO
